{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist-server",
    "rootDir": "..",
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true
  },
  "include": ["./**/*.ts", "../src/state_management/types.ts"]
}
